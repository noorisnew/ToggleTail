# MySQL Database (Prisma)
# Create the DB first: mysql -u root -p -e "CREATE DATABASE toggletail CHARACTER SET utf8mb4;"
# Then run: cd backend && npm run db:migrate
DATABASE_URL="mysql://root:YOUR_MYSQL_PASSWORD@localhost:3306/toggletail"

# JWT Secret (change to a long random string in production)
JWT_SECRET=your-jwt-secret-change-in-production

# OpenAI API Key (required for AI story generation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ElevenLabs API Key (optional - fallback to device TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Server Port
PORT=3001

# Production only — restrict CORS to this origin
# FRONTEND_URL=https://your-app.example.com
