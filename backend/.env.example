# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/toggletail?retryWrites=true&w=majority

# JWT Secret (for authentication)
JWT_SECRET=your-jwt-secret-change-in-production

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# ElevenLabs API Key (optional - fallback to device TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Server Port
PORT=3001
